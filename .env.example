PORT=3000
SQLITE_PATH=

# ── Config del club por defecto (semilla al arrancar por primera vez) ──────────

# Slug unico que aparece en la URL: tuapp.com/cmr-futbol
CLUB_SLUG=cmr-futbol

# Nombre visible del club
CLUB_NOMBRE=Club CMR Futbol

# Deporte: futbol | tenis | padel | multideporte
CLUB_DEPORTE=futbol

# Canchas: nombres separados por coma (estos valores se guardan en la BD)
CLUB_CANCHAS=11,7

# Etiquetas visibles en el frontend (mismo orden que CLUB_CANCHAS)
CLUB_CANCHAS_ETIQUETAS=Cancha 11,Cancha 7

# Horario de apertura y cierre (en horas enteras)
CLUB_HORA_INICIO=10
CLUB_HORA_FIN=23

# Precio de la seña en pesos
CLUB_PRECIO=12000

# ── Datos de transferencia ──────────────────────────────────────────────────────
WHATSAPP_NUMERO=5491112345678
TRANSFER_ALIAS=mi.alias.real
TRANSFER_CBU=0000003100099999999999
TRANSFER_TITULAR=Nombre Apellido

# ── Credenciales de admin ───────────────────────────────────────────────────────
# Clave principal del panel admin
ADMIN_PASSWORD=admin123
# Clave secundaria opcional (ej: para un segundo administrador)
ADMIN_PASSWORD_SECOND=lucas123
# Secreto para firmar los tokens de sesion (cambiarlo en produccion)
ADMIN_SESSION_SECRET=cambia_esta_clave

# ── Opcionales: Vercel KV (cache serverless) ───────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Opcionales: Supabase (base de datos cloud) ─────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=comprobantes
